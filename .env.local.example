# Copy this file to .env.local and fill in your Supabase project credentials.
# Get these from: https://supabase.com/dashboard -> your project -> Settings -> API

# Supabase project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (safe to expose to the browser; RLS controls access)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: Supabase service-role key — only for server-side admin routes.
# NEVER expose this to the browser. Keep this secret.
# SUPABASE_SERVICE_ROLE_KEY=

# ── SEO / GEO ─────────────────────────────────────────────────────────────────
# Canonical site origin — used for canonical tags, hreflang, sitemap, JSON-LD,
# and the OG image URL. Falls back to https://tokenforest.com.au if unset.
# Set this per environment (e.g. the Netlify deploy URL on preview builds).
NEXT_PUBLIC_SITE_URL=https://tokenforest.com.au

# Privacy-friendly, cookieless analytics (Plausible). The domain you registered
# in Plausible, e.g. tokenforest.com.au. Leave blank to disable the script.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Google Search Console verification token (the content of the meta tag).
# Server-only — never shipped to the client bundle.
GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools verification token (the msvalidate.01 value).
# Server-only.
BING_SITE_VERIFICATION=
